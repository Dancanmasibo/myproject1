@page "/daily-report/print"
@using myproject1.Data
@using myproject1.Respositories
@inject ExpenseServices expenseService
@using myproject1.Components.Layout
@layout PrintLayout
@inject IJSRuntime JS

<h2 class="expenses-title">
    Expenses for @selectedDate.ToString("dddd, dd MMM yyyy")
</h2>
<hr class="title-line" />

<div class="mb-3">
    <label>Select Date:</label>
    <InputDate @bind-Value="selectedDate" class="form-control" />
    <button class="btn btn-primary mt-2" @onclick="PrintExpenseAsync">Generate Report</button>
</div>

@if (dailyExpenses == null)
{
    <p><em>Loading...</em></p>
    <div class="spinner"></div>
}
else if (dailyExpenses.Count > 0)
{
    <div class="chart-container mt-4">
        <table class="table table-striped border table-responsive-sm">
            <thead class="table-secondary">
                <tr>
                    <th>Id</th>
                    <th>Date</th>
                    <th>Category</th>
                    <th>Description</th>
                    <th>Amount (Ksh)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var expense in dailyExpenses)
                {
                    <tr>
                        <td>@expense.Id</td>
                        <td>@expense.date.ToShortDateString()</td>
                        <td>@expense.category</td>
                        <td>@expense.description</td>
                        <td>@expense.amount.ToString("N2")</td>
                    </tr>
                }
                <tr>
                    <td colspan="4" style="font-weight: bold; text-align: right; background-color: white; color: black;">
                        Total
                    </td>
                    <td style="font-weight: bold; text-align: right; background-color: white; color: black;">
                        @dailyExpenses.Sum(e => e.amount).ToString("N2")
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
}
else
{
    <p>No expenses found for this day.</p>
}

@code {
    private List<Expense> dailyExpenses;
    private DateTime selectedDate = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        await LoadExpensesForDay();
    }

    public async Task LoadExpensesForDay()
    {
        var expenses = await expenseService.GetAllExpensesAsync();
        dailyExpenses = expenses
            .Where(e => e.date.Date == selectedDate.Date)
            .OrderBy(e => e.date)
            .ToList();
    }
    public async Task PrintExpenseAsync()
    {
        await Task.Delay(3000);
        await JS.InvokeVoidAsync("window.print");
        

    }
}
<style>
    :root {
        --bg: #0b0f1a;
        --surface: #131929;
        --surface2: #1a2236;
        --border: #1f2e47;
        --accent: #00d4ff;
        --accent2: #7c5cfc;
        --green: #00e5a0;
        --red: #ff4d6d;
        --yellow: #ffd166;
        --text: #e8eaf0;
        --muted: #5a6a85;
        --card: #161f33;
    }


    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        overflow-x: hidden;
    }

    .value {
        font-size: 2rem;
        font-weight: bold;
        margin-top: 10px;
    }

    .chart-container {
        background-color: black;
        border-radius: 8px;
        padding: 20px;
        width: 100%;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        border: 2px solid #800080;
        text-align: center;
    }

    * Table header styling */
    .table thead th {
        background-color: black;
        color: white;
        font-weight: bold;
        text-align: center;
        border: 1px solid black;
    }

    /* Table body cells styling */
    .table tbody td {
        background-color: white;
        color: black;
        border: 1px solid black;
    }

    .expenses-title {
        font-weight: bold;
        text-decoration: underline double;
    }
</style>
