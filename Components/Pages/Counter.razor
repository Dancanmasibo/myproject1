@page "/counter"
@using myproject1.Data
@using myproject1.Respositories
@inject ExpenseServices expenseService;


<div id="page-expenses" class="page">
    <div class="page-header">
        <h2>Expenses</h2>
        <p>Manage and track your expenditures</p>
    </div>
</div>
@* <div></div> class for responsive view *@
@* <table class="table table-striped table-responsive-sm"></table>
<thead class="table-secondary">
    <tr>
        <td>ID</td>
        <td>Type</td>
        <td>Date</td>
        <td>Action</td>
    </tr>
</thead> *@
<a href="/add-expense" class="btn btn-primary mt-4">Add Expense</a>
<div class="col">
</div>
<div><p></p></div>
@if (expenseList == null)
{
    <p><em>Loading...</em></p>
    <div class="spinner"></div>
}
else
{
    if (expenseList.Count() > 0)
    {
        <div class="row">
            <div class="col align-content-md-around col-md-12 card">

                <table class="table table-striped border table-responsive-sm">
                    <thead class="table-secondary">
                        <tr>
                            <th>Id</th>
                            <th>Date</th>
                            <th>Category</th>
                            <th>Description</th>
                            <th>Amount(Ksh)</th>
                            <th>Modify</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Expense expense in expenseList)
                        {
                            int id = expense.Id;
                            <tr>
                                <td>@expense.Id</td>
                                <td>@expense.date.ToShortDateString()</td>
                                <td>@expense.category</td>
                                <td>@expense.description</td>
                                <td>@expense.amount</td>
                                <td>
                                    <a class="btn btn-warning" href="/editExpense/@expense.Id">Edit</a>

                                    <button @onclick="(() => dropExpensesAsync(id))" class="btn btn-danger btn-sm mb-1 "> <i class="bi bi-trash"></i>Delete</button>

                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        </div>
    }
    else
    {
        <p>no expenses Available</p>
    }
}
@* <Delete_Dialog ShowDeleteDialog="showConfigDialog" oncancel="cancelConfigDialog">  </Delete_Dialog> *@

@code {
    private bool showConfigDialog;

    //list to store variables
    public Expense expense { get; set; }
    public List<Expense> expenseList { get; set; }

    //method to get all expenses
    public async Task loadExpensesAsync()
    {
        expenseList = (List<Expense>)await expenseService.GetAllExpensesAsync();
    }

    //overriding task async
    protected override async Task OnInitializedAsync()
    {
        await loadExpensesAsync();
    }

    private void openConfigDialog()
    {
        showConfigDialog = true;
    }
    private void cancelConfigDialog()
    {
        showConfigDialog = false;
    }
    public async Task dropExpensesAsync(int Id)
    {
        var deleteditem = await expenseService.deleteExpenseAsync(Id);

        if (deleteditem is not null && deleteditem.Id != 0)
        {
            expenseList.Remove(deleteditem);
        }
    }

}
