@page "/monthly-report.view"
@using myproject1.Data
@using myproject1.Respositories
@inject ExpenseServices expenseService;
@using myproject1.Components.Layout
@layout PrintLayout

<div id="page-expenses" class="page">
    <div class="expenses-title">
        <h2>Monthly Expense Report</h2>
    </div>
</div>
<hr class="title-line" />
@if (monthlyExpenses == null)
{
    <p><em>Loading...</em></p>
    <div class="spinner"></div>
}
else
{
    if (monthlyExpenses.Count > 0)
    {
        @foreach (var group in monthlyExpenses)
        {
            <div class="chart-container mt-4">
                <h5>@group.Key.ToString("MMMM yyyy")</h5>
                <table class="table table-striped border table-responsive-sm">
                    <thead class="table-secondary">
                        <tr>
                            <th>Id</th>
                            <th>Date</th>
                            <th>Category</th>
                            <th>Description</th>
                            <th>Amount(Ksh)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var expense in group)
                        {
                            <tr>
                                <td>@expense.Id</td>
                                <td>@expense.date.ToShortDateString()</td>
                                <td>@expense.category</td>
                                <td>@expense.description</td>
                                <td>@expense.amount</td>
                            </tr>
                            
                        }
                        <tr>
                            <td colspan="4" style="font-weight: bold; text-align: right; color: black;">
                                Total
                            </td>
                            <td style="font-weight: bold; text-align: right; color: black;">
                                @group.Sum(e => e.amount)
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }
    }
    else
    {
        <p>No expenses available</p>
    }
}

@code {
    public List<IGrouping<DateTime, Expense>> monthlyExpenses { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var expenses = await expenseService.GetAllExpensesAsync();
        monthlyExpenses = expenses
            .GroupBy(e => new DateTime(e.date.Year, e.date.Month, 1))
            .OrderByDescending(g => g.Key)
            .ToList();
    }

    
}
<style>
    :root {
        --bg: #0b0f1a;
        --surface: #131929;
        --surface2: #1a2236;
        --border: #1f2e47;
        --accent: #00d4ff;
        --accent2: #7c5cfc;
        --green: #00e5a0;
        --red: #ff4d6d;
        --yellow: #ffd166;
        --text: #e8eaf0;
        --muted: #5a6a85;
        --card: #161f33;
    }


    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        overflow-x: hidden;
    }
    .value {
        font-size: 2rem;
        font-weight: bold;
        margin-top: 10px;
    }

    .chart-container {
        background-color: black;
        border-radius: 8px;
        padding: 20px;
        width: 100%;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        border: 2px solid #800080;
        text-align: center;
    }

    * Table header styling */
    .table thead th {
        background-color: black;
        color: white;
        font-weight: bold;
        text-align: center;
        border: 1px solid black;
    }

    /* Table body cells styling */
    .table tbody td {
        background-color: white;
        color: black;
        border: 1px solid black;
    }

    expenses-title {
        text-align: center; /* Centers the text */
        margin-bottom: 10px; /* Adds spacing before the line */
        font-weight: bold; /* Optional: makes the title stand out */
    }


    .title-line {
        border: none; /* Removes default styling */
        border-top: 2px solid #333; /* Creates a custom horizontal line */
        width: 60%; /* Line width relative to page */
        margin: 0 auto; /* Centers the line */
    }

</style>