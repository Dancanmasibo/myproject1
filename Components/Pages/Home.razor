@page "/"
@using myproject1.Data
@using myproject1.Respositories
@inject ExpenseServices expenseService

<div id="page-title" class="page active">
    <div class="page-header">
        <h2>MY DAASHBOARD</h2>

    </div>
</div>

<!-- Stats Cards -->
<div class="dashboard-container">
    <div class="card">
        <span>TOTAL EXPENSES</span>
        <div class="value">@($"{totalExpenses:C}")</div>
    </div>
    <div class="card">
        <span>AVERAGE MONTHLY EXPENDITURE</span>
        <div class="value">@($"{averageMonthly:C}")</div>
    </div>
    <div class="card">
        <span>HIGHEST CATEGORY</span>
        <div class="value">@highestCategory</div>
    </div>
    <div class="card">
        <span>THIS MONTH </span>
        <div class="value">@($"{thisMonth:C}")</div>
    </div>
</div>



@code
{
    public List<Expense> expenseList { get; set; }

    // Dashboard variables
    public decimal totalExpenses { get; set; }
    public string averageMonthly { get; set; } = "0";
    public string thisMonth { get; set; } = "0";
    public string highestCategory { get; set; } = "N/A";

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardDataAsync();
    }

    private async Task LoadDashboardDataAsync()
    {
        expenseList = (List<Expense>)await expenseService.GetAllExpensesAsync();

        if (expenseList != null && expenseList.Count > 0)
        {
            totalExpenses = expenseList.Sum(e => e.amount);
            averageMonthly = expenseList.Average(e => e.amount).ToString("F2");

            highestCategory = expenseList
            .GroupBy(e => e.category)
            .OrderByDescending(g => g.Sum(x => x.amount))
            .First().Key;

            // Calculate this month's total
            var currentMonth = DateTime.Now.Month;
            var currentYear = DateTime.Now.Year;

            var monthlyTotal = expenseList
            .Where(e => e.date.Month == currentMonth && e.date.Year == currentYear)
            .Sum(e => e.amount);

            thisMonth = monthlyTotal.ToString("F2");
        }
    }


}
